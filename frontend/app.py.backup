"""
Health Literacy Assistant - Frontend Container
Built with assistance from AI (Claude) for:
- Streamlit app structure
- API client implementation
- Docker configuration

Human modifications:
- Customized for FHIR resource display
- Added medical terminology translations
- Deployed to cloud platform
"""

import streamlit as st
import sys
import os
import pandas as pd
from datetime import datetime

sys.path.append(os.path.dirname(__file__))

from utils.api_client import APIClient

# Page config
st.set_page_config(
    page_title="Health Literacy Assistant",
    page_icon="🏥",
    layout="wide",
    initial_sidebar_state="expanded"
)

# Initialize API client
@st.cache_resource
def init_api_client():
    api_url = os.getenv("API_URL", "http://backend:5000")
    return APIClient(base_url=api_url)

def init_session_state():
    if 'api_client' not in st.session_state:
        st.session_state.api_client = init_api_client()
    if 'patient_data' not in st.session_state:
        st.session_state.patient_data = None
    if 'selected_fhir_resource' not in st.session_state:
        st.session_state.selected_fhir_resource = None
    if 'explanation' not in st.session_state:
        st.session_state.explanation = None
    if 'current_view' not in st.session_state:
        st.session_state.current_view = "dashboard"

init_session_state()

# Sidebar
with st.sidebar:
    st.image("https://img.icons8.com/color/96/hospital.png", width=80)
    st.title("🏥 Health Literacy Assistant")
    st.markdown("*Making medical jargon understandable*")
    st.markdown("---")
    
    # System Status
    st.subheader("🔌 System Status")
    health = st.session_state.api_client.health_check()
    
    col1, col2 = st.columns(2)
    with col1:
        if health.get("backend"):
            st.success("✅ RAG Engine")
        else:
            st.error("❌ RAG Engine")
    with col2:
        if health.get("database"):
            st.success("✅ Knowledge Base")
        else:
            st.error("❌ Knowledge Base")
    
    st.markdown("---")
    
    # Navigation
    st.subheader("📱 Navigation")
    view = st.radio(
        "Select View",
        ["🏠 Patient Dashboard", "📋 Medical Records", "💬 Ask Assistant"],
        label_visibility="collapsed"
    )
    
    if view == "🏠 Patient Dashboard":
        st.session_state.current_view = "dashboard"
    elif view == "📋 Medical Records":
        st.session_state.current_view = "records"
    elif view == "💬 Ask Assistant":
        st.session_state.current_view = "assistant"
    
    st.markdown("---")
    
    # Patient selector (mock for now)
    st.subheader("👤 Patient")
    patient_id = st.selectbox(
        "Select Patient",
        ["Patient #1001 (Synthetic)", "Patient #1002 (Synthetic)", "Patient #1003 (Synthetic)"],
        help="Synthetic data from Synthea"
    )
    
    st.markdown("---")
    st.caption("🏥 RAG-Powered Health Literacy Assistant")
    st.caption("v1.0 | Grounded in trusted medical sources")

# Main Content
if st.session_state.current_view == "dashboard":
    # Dashboard View
    st.title("🏥 Welcome to Your Health Literacy Assistant")
    st.markdown("### Understanding your health information, made simple")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.info("""
        **How it works:**
        1. 📋 View your medical records
        2. 🔍 Select any medical term or lab result
        3. 💬 Get a plain-language explanation
        4. 📚 See trusted sources for reference
        """)
    
    with col2:
        st.success("""
        **Recent Activity:**
        - ✅ 3 medical terms explained
        - ✅ 2 lab results simplified
        - ✅ 1 medication instruction clarified
        """)
    
    st.markdown("---")
    
    # Quick translation demo
    st.subheader("🔍 Try It Now")
    st.write("Select a medical term to see it explained in plain language:")
    
    demo_terms = [
        "Hypertension",
        "Hyperlipidemia",
        "Type 2 Diabetes Mellitus",
        "Myocardial Infarction",
        "Chronic Kidney Disease"
    ]
    
    selected_term = st.selectbox("Medical Term", demo_terms)
    
    if st.button("Explain This Term", type="primary"):
        with st.spinner("Generating explanation using RAG..."):
            # This would call your backend API
            st.session_state.explanation = f"""
            **Plain Language Explanation:**
            
            **{selected_term}** means:
            
            [This would be the AI-generated plain-language explanation 
            grounded in your knowledge base]
            
            **Source:** MedlinePlus Medical Encyclopedia
            """
    
    if st.session_state.explanation:
        st.markdown("---")
        st.markdown("### 📖 Explanation")
        st.markdown(st.session_state.explanation)
        st.caption("🔗 Source: Trusted Medical Database")

elif st.session_state.current_view == "records":
    # Medical Records View
    st.title("📋 Your Medical Records")
    st.markdown("*Clinical terms can be clicked to get plain-language explanations*")
    
    # Tabs for different FHIR resources
    tab1, tab2, tab3, tab4 = st.tabs([
        "🏷️ Conditions", 
        "🧪 Lab Results", 
        "💊 Medications", 
        "📄 Clinical Notes"
    ])
    
    with tab1:
        st.subheader("Diagnoses & Conditions")
        
        # Mock conditions data (would come from backend)
        conditions = [
            {"condition": "Essential hypertension", "status": "Active", "date": "2024-01-15"},
            {"condition": "Type 2 diabetes mellitus", "status": "Active", "date": "2023-08-22"},
            {"condition": "Hyperlipidemia", "status": "Active", "date": "2024-01-15"}
        ]
        
        for cond in conditions:
            col1, col2, col3 = st.columns([3, 1, 1])
            with col1:
                st.write(f"**{cond['condition']}**")
            with col2:
                st.write(cond['status'])
            with col3:
                if st.button("Explain", key=f"explain_{cond['condition']}"):
                    st.session_state.selected_fhir_resource = cond
                    st.session_state.current_view = "assistant"
                    st.rerun()
        
        st.caption("💡 Click 'Explain' to get a plain-language version of any condition")
    
    with tab2:
        st.subheader("Lab Results")
        
        # Mock lab results
        labs = [
            {"test": "Hemoglobin A1c", "value": "7.2%", "reference": "<5.7%", "flag": "⚠️ High"},
            {"test": "LDL Cholesterol", "value": "130 mg/dL", "reference": "<100 mg/dL", "flag": "⚠️ High"},
            {"test": "Blood Pressure", "value": "135/85", "reference": "<120/80", "flag": "⚠️ Elevated"}
        ]
        
        df = pd.DataFrame(labs)
        st.dataframe(df, use_container_width=True)
        
        st.caption("💡 Click any lab value to get a plain-language explanation")
    
    with tab3:
        st.subheader("Current Medications")
        
        medications = [
            {"medication": "Lisinopril 10mg", "instructions": "Take once daily", "purpose": "Blood pressure"},
            {"medication": "Metformin 500mg", "instructions": "Take with meals", "purpose": "Blood sugar"},
            {"medication": "Atorvastatin 20mg", "instructions": "Take at bedtime", "purpose": "Cholesterol"}
        ]
        
        for med in medications:
            with st.expander(f"💊 {med['medication']}"):
                st.write(f"**Instructions:** {med['instructions']}")
                st.write(f"**Purpose:** {med['purpose']}")
                if st.button("Simplify Instructions", key=f"simplify_{med['medication']}"):
                    st.session_state.selected_fhir_resource = med
                    st.session_state.current_view = "assistant"
                    st.rerun()
    
    with tab4:
        st.subheader("Clinical Notes")
        
        clinical_note = """
        **Visit Summary - March 15, 2024**
        
        Patient presents with worsening hypertension. Current BP 145/92. 
        A1c elevated at 7.2%. Will increase Lisinopril to 20mg daily. 
        Continue metformin. Follow up in 3 months.
        """
        
        st.text_area("Clinical Note", clinical_note, height=200)
        
        if st.button("Translate to Plain Language"):
            st.session_state.current_view = "assistant"
            st.rerun()

elif st.session_state.current_view == "assistant":
    # RAG Assistant View - Before/After Translation
    st.title("💬 Health Literacy Assistant")
    st.markdown("*Get plain-language explanations for medical terms*")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.subheader("📄 Medical Jargon (Original)")
        st.markdown("---")
        
        if st.session_state.selected_fhir_resource:
            if "condition" in st.session_state.selected_fhir_resource:
                st.markdown(f"**Condition:** {st.session_state.selected_fhir_resource['condition']}")
                st.markdown(f"**Status:** {st.session_state.selected_fhir_resource['status']}")
                st.markdown(f"**Date:** {st.session_state.selected_fhir_resource['date']}")
            elif "medication" in st.session_state.selected_fhir_resource:
                st.markdown(f"**Medication:** {st.session_state.selected_fhir_resource['medication']}")
                st.markdown(f"**Instructions:** {st.session_state.selected_fhir_resource['instructions']}")
                st.markdown(f"**Purpose:** {st.session_state.selected_fhir_resource['purpose']}")
            else:
                st.markdown("Select a medical term from the Records view to see explanation")
        else:
            st.markdown("""
            **Example Medical Jargon:**
            
            > "Essential hypertension with elevated A1c levels indicating poor glycemic control"
            """)
    
    with col2:
        st.subheader("💡 Plain Language (After)")
        st.markdown("---")
        
        # This is where the RAG-generated explanation would appear
        if st.session_state.selected_fhir_resource:
            with st.spinner("Generating explanation using RAG..."):
                # Mock explanation - would come from backend
                st.markdown("""
                **Your Simplified Explanation:**
                
                🌟 **Hypertension** means your blood pressure is higher than normal. 
                Think of it like water flowing through a pipe - when pressure is too high, 
                it can strain the pipes over time.
                
                📊 **A1c** is like a report card for your blood sugar over the past 3 months. 
                A lower number means better blood sugar control.
                
                **What this means for you:**
                - Your blood pressure needs monitoring
                - Your diabetes management may need adjustment
                - Talk to your doctor about lifestyle changes
                
                ---
                **Sources:**
                - 📚 American Heart Association
                - 📚 American Diabetes Association
                - 📚 MedlinePlus (NIH)
                """)
        else:
            st.markdown("""
            **Plain Language Explanation:**
            
            > Your blood pressure is higher than normal, and your blood sugar levels 
            > have been running high over the past few months. This means we should 
            > review your medications and lifestyle habits to get these numbers 
            > into a healthier range.
            
            **Sources:**
            - 📚 American Heart Association
            - 📚 American Diabetes Association
            """)
    
    # Action buttons
    st.markdown("---")
    col1, col2, col3 = st.columns(3)
    
    with col1:
        if st.button("🔍 Ask a Follow-up Question", use_container_width=True):
            st.info("Type your question below:")
            question = st.text_input("Your question:")
            if question:
                st.write("Processing your question...")
    
    with col2:
        if st.button("📋 Save This Explanation", use_container_width=True):
            st.success("Saved to your health library!")
    
    with col3:
        if st.button("← Back to Records", use_container_width=True):
            st.session_state.current_view = "records"
            st.rerun()
    
    # Disclaimer
    st.markdown("---")
    st.caption("⚠️ This information is for educational purposes. Always consult your healthcare provider.")
